<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Geometric low-poly heart outline with internal facet lines.
        All vertices kept within the adaptive-icon safe zone (18-90 dp).

        Outer polygon (clockwise from top-center V):
          (54,36) (42,27) (29,26) (22,34) (22,48) (30,60)
          (54,82) (78,60) (86,48) (86,34) (79,26) (66,27)
        Internal lines:
          Left lobe X:  (29,26)→(22,48)  and  (22,34)→(42,27)
          Right lobe X: (79,26)→(86,48)  and  (86,34)→(66,27)
          Inner diagonals: (42,27)→(30,60)  and  (66,27)→(78,60)
          Lower-V:      (30,60)→(54,36)  and  (78,60)→(54,36)
    -->
    <path
        android:fillColor="#00000000"
        android:pathData="M 54,36 L 42,27 L 29,26 L 22,34 L 22,48 L 30,60
                          L 54,82 L 78,60 L 86,48 L 86,34 L 79,26 L 66,27 Z
                          M 29,26 L 22,48
                          M 22,34 L 42,27
                          M 79,26 L 86,48
                          M 86,34 L 66,27
                          M 42,27 L 30,60
                          M 66,27 L 78,60
                          M 30,60 L 54,36
                          M 78,60 L 54,36"
        android:strokeColor="@color/launcher_heart_stroke"
        android:strokeWidth="2.5"
        android:strokeLineJoin="round"
        android:strokeLineCap="round" />

    <!-- ECG waveform: flat baseline with QRS spike and T wave -->
    <path
        android:fillColor="#00000000"
        android:pathData="M 22,58 L 34,58 L 37,61 L 42,50 L 48,38
                          L 53,66 L 57,58 L 65,58 L 68,53 L 72,48
                          L 76,58 L 86,58"
        android:strokeColor="@color/launcher_pulse"
        android:strokeWidth="2.5"
        android:strokeLineJoin="round"
        android:strokeLineCap="round" />

</vector>
